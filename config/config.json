{
  "proxies": [
    {
      "type": "webhook",
      "source": {
        "path": "/webhook/location",
        "method": "POST",
        "variables": {
          "latitude": "body.event.data.new_state.attributes.latitude",
          "longitude": "body.event.data.new_state.attributes.longitude",
          "device": "body.event.data.entity_id"
        }
      },
      "destination": {
        "url": "http://host.docker.internal:4000/api/target/location",
        "method": "GET",
        "query": {
          "lat": "{{latitude}}",
          "lon": "{{longitude}}",
          "device_id": "{{device}}"
        },
        "headers": {
          "Authorization": "Bearer local_test_token"
        }
      }
    },
    {
      "type": "polling",
      "schedule": "*/5 * * * * *",
      "source": {
        "url": "http://host.docker.internal:4000/api/source/status",
        "method": "GET",
        "headers": {
          "Accept": "application/json"
        },
        "variables": {
          "system_status": "body.status.system",
          "uptime_val": "body.status.uptime",
          "auth_header": "headers.authorization"
        }
      },
      "destination": {
        "url": "relay://status_relay",
        "method": "POST",
        "body": {
          "state": "{{system_status}}",
          "up": "{{uptime_val}}",
          "source_auth": "{{auth_header}}"
        },
        "headers": {
          "Content-Type": "application/json"
        }
      }
    }
  ]
}
